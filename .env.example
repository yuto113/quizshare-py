# ひみつの鍵(ぜんぶの暗号化に使うよ)
# ランダムな32文字以上の文字列を入れてね
# 作り方: python -c "import secrets; print(secrets.token_hex(32))"
PEPPER=change-me-to-a-random-string-of-at-least-32-chars

# Flaskのセッション(ログイン状態を保つために使う)
FLASK_SECRET_KEY=change-me-to-another-random-string

# データベース接続先
# Railwayにデプロイすると自動で入るから、ローカル以外は触らなくてOK
# ローカルで動かすときは、空欄にすればSQLiteが自動で使われるよ
DATABASE_URL=

# 開発モード(1にするとデバッグ表示、本番は0)
FLASK_DEBUG=0
